{
  // Spark release automation. Run: asc workflow run ship-ios VERSION:2.2.0
  "env": {
    "IOS_APP_ID": "6785162492",
    "MAC_APP_ID": "6785162492",
    "VERSION": "",
    "SUBMIT": "true"
  },
  "before_all": "asc auth status",
  "workflows": {
    "ship-ios": {
      "description": "Bump, archive, upload, and submit the iOS app",
      "steps": [
        { "name": "bump", "run": "cd ios && asc xcode version edit --version \"$VERSION\" --build-number \"$(date +%Y%m%d%H%M)\"" },
        { "name": "archive", "run": "cd ios && asc xcode archive --project Spark.xcodeproj --scheme Spark --archive-path ../.asc/artifacts/Spark.xcarchive --xcodebuild-flag=-skipPackagePluginValidation --output json" },
        { "name": "export", "run": "cd ios && asc xcode export --archive-path ../.asc/artifacts/Spark.xcarchive --export-options ExportOptions.plist --ipa-path ../.asc/artifacts/Spark.ipa --output json" },
        { "name": "publish", "if": "SUBMIT", "run": "asc publish appstore --app $IOS_APP_ID --ipa .asc/artifacts/Spark.ipa --version $VERSION --wait --submit --confirm --output json" }
      ]
    },
    "ship-mac": {
      "description": "Bump, archive, upload, and submit the Mac app",
      "steps": [
        { "name": "bump_mac", "run": "cd macos && asc xcode version edit --version \"$VERSION\" --build-number \"$(date +%Y%m%d%H%M)\"" },
        { "name": "archive_mac", "run": "cd macos && asc xcode archive --project SparkMac.xcodeproj --scheme SparkMac --archive-path ../.asc/artifacts/SparkMac.xcarchive --output json" },
        { "name": "export_mac", "run": "cd macos && asc xcode export --archive-path ../.asc/artifacts/SparkMac.xcarchive --export-options ExportOptions.plist --pkg-path ../.asc/artifacts/SparkMac.pkg --output json" },
        { "name": "publish_mac", "if": "SUBMIT", "run": "asc publish appstore --app $MAC_APP_ID --pkg .asc/artifacts/SparkMac.pkg --version $VERSION --wait --submit --confirm --output json" }
      ]
    }
  }
}
